@startuml
title Communication Diagram: Chat Interaction

' --- CẤU HÌNH GIAO DIỆN ---
skinparam shadowing false
allow_mixing
skinparam linestyle default

' --- QUAN TRỌNG: Tăng cỡ chữ và khoảng cách ---
skinparam defaultFontSize 50
skinparam nodesep 200
skinparam ranksep 200

' --- KHAI BÁO OBJECT ---
actor User
object "ChatInterface" as UI
object "ChatController" as Controller
object "CharacterService" as CharService
object "ChatSessionService" as SessionService
object "AIService" as AI
object "MessageService" as MsgService

' --- TẠO KHUNG XƯƠNG (LAYOUT) ---
' Hàng 1: User -> UI -> Controller
User -[hidden]right- UI
UI -[hidden]right- Controller

' Hàng 2: Các Service nằm dưới Controller
Controller -[hidden]down- AI

' Sắp xếp các service ngang hàng nhau
CharService -[hidden]right- SessionService
SessionService -[hidden]right- AI
AI -[hidden]right- MsgService

' --- VẼ DÂY VÀ ĐIỀN TEXT ---

' == Flow 1: Initialize Chat ==
User .right.> UI : 1: select character
UI ----> Controller : 2: initializeChat()

' Controller calls Services (Init)
Controller ----> CharService : 2.1: loadCharacterData()
Controller ----> SessionService : 2.2: createSession()
Controller ----> AI : 2.3: generateSuggestedQuestions()

' Return Init Data
Controller .left.> UI : 2.4: return sessionData
UI .left.> User : 2.5: display chat interface

' == Flow 2: Send Message ==
User .right.> UI : 3: send message
UI ----> Controller : 3.1: sendMessage()

' Save User Message
Controller ----> MsgService : 3.1.1: saveMessage(userMsg)

' Get AI Response
Controller ----> AI : 3.2: getCharacterResponse()

' Save AI Message
Controller ----> MsgService : 3.3: saveMessage(aiMsg)

' Return Response
Controller .left.> UI : 3.4: return response
UI .left.> User : 3.5: display response

@enduml