' @startuml
' title Communication Diagram: Login

' ' --- 1. CẤU HÌNH GIAO DIỆN ---
' skinparam shadowing false
' allow_mixing
' skinparam linestyle default
' skinparam defaultFontSize 40

' ' Tăng khoảng cách cực đại
' skinparam nodesep 150
' skinparam ranksep 150

' ' BÍ KÍP: Tự động ngắt dòng nếu text dài hơn 400px
' ' Giúp text không bị dài thòng lòm đè lên dây khác
' skinparam wrapWidth 400

' ' --- 2. KHAI BÁO OBJECT ---
' actor "Registered User / Admin" as User
' object "LoginView" as View
' object "AuthController" as Controller
' object "AuthService" as Service
' object "UserDataWrapper" as UserDB
' object "StaffDataWrapper" as StaffDB

' ' --- 3. LAYOUT (CHIẾN THUẬT LA BÀN) ---
' ' Hàng 1: User -> View -> Controller
' User -[hidden]right- View
' View -[hidden]right- Controller

' ' Hàng 2: Service nằm dưới Controller
' Controller -[hidden]down- Service

' ' Hàng 3: Tách StaffDB và UserDB ra 2 hướng khác nhau hoàn toàn
' ' StaffDB nằm bên TRÁI Service
' StaffDB -[hidden]right- Service

' ' UserDB nằm bên DƯỚI Service
' Service -[hidden]down- UserDB

' ' --- 4. LUỒNG ĐI (VẼ DÂY) ---

' ' User -> View
' User .right.> View : enter {username, password}
' View .left.> User : 1.3: store token + redirect

' ' View -> Controller -> Service
' View -----> Controller : 1: login(user, pass)
' Controller -----> Service : 1.1: authenticate()
' Service .up.> Controller : 1.2: token + redirect info

' ' --- KHÔNG GIAN RIÊNG CHO TỪNG SERVICE ---

' ' 1. Service -> UserDB (Đi xuống DƯỚI)
' Service -down----> UserDB : 1.1.1: findUserByUserName()\n1.1.2: user record

' ' 2. Service -> StaffDB (Đi sang TRÁI)
' ' Mũi tên dài để text không dính vào box
' Service -left----> StaffDB : 1.1.5: [if UserType='Staff'] get Role\n1.1.6: Role info

' ' 3. Self-Call (Đi sang PHẢI)
' ' Vì StaffDB ở trái, UserDB ở dưới, nên bên PHẢI hoàn toàn trống trải cho Self-call
' Service -right-> Service : 1.1.3: verify hash\n1.1.4: build JWT

' @enduml

@startuml
title Communication Diagram: Login 
skinparam linestyle ortho
skinparam rectangle {
    BackgroundColor SkyBlue
    BorderColor Black
}
' Khoảng cách rộng để text không đè lên dây
skinparam nodesep 120
skinparam ranksep 100

actor "User" as user
rectangle ":LoginUI" as ui
rectangle ":SecurityManager" as sec
rectangle "u:User" as u_ent
rectangle "s:Staff" as s_ent
rectangle "r:Role" as r_ent

' --- 1. ĐỊNH VỊ KHUNG LƯỚI (TOPOLOGY) ---
' Hàng ngang chính: User -> UI -> SecurityManager -> Role
user -[hidden]right- ui
ui -[hidden]right- sec
sec -[hidden]right- r_ent

' Các vệ tinh xoay quanh SecurityManager:
' Staff nằm bên TRÊN SecurityManager
sec -[hidden]up- s_ent
' User Entity nằm bên DƯỚI SecurityManager
sec -[hidden]down- u_ent


' --- 2. VẼ CÁC LIÊN KẾT & THÔNG ĐIỆP (Forward Only) ---

' 1. User -> UI (Sang phải)
user -right-> ui : 1: Enter {username, password} \n 2: Click Login

' 1.1. UI -> SecurityManager (Sang phải)
ui -right-> sec : 1.1: authenticate(user, pass)

' 1.1.1 & 1.1.2. SecurityManager -> User Entity (Đi xuống)
sec -down-> u_ent : 1.1.1: findByUsername() \n 1.1.2: verifyPassword()

' 1.1.3. SecurityManager -> Staff Entity (Đi lên)
sec -up-> s_ent : 1.1.3: [if UserType='Staff'] getStaffInfo()

' 1.1.4. SecurityManager -> Role Entity (Sang phải)
sec -right-> r_ent : 1.1.4: getRoleDetails()

' 1.2. UI tự cập nhật trạng thái (Self Call)
ui -up-> ui : 1.2: display dashboard (sessionToken)

@enduml