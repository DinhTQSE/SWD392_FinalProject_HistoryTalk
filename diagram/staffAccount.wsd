@startuml
title Communication Diagram: Staff Account Onboarding

skinparam shadowing false
allow_mixing
skinparam linestyle default
skinparam nodesep 100
skinparam ranksep 100

' --- 1. Participants ---
actor "Admin" as Admin
object "StaffManagementView" as View
object "StaffController" as Controller
object "StaffService" as StaffService
object "StaffDataWrapper" as StaffDB
object "UserService" as UserService
object "UserDataWrapper" as UserDB

' --- 2. Layout Skeleton ---
Admin -[hidden]right- View
View -[hidden]right- Controller
Controller -[hidden]down- StaffService

' StaffService phân nhánh
StaffDB -[hidden]right- StaffService
StaffService -[hidden]right- UserService
UserService -[hidden]down- UserDB

' --- 3. Connections & Messages ---

' Admin Interaction
Admin .right.> View : enter staff info
View .left.> Admin : 1.3: show result

' MVC Flow
View ----> Controller : 1: onboardStaff(data)
Controller ----> StaffService : 1.1: processOnboarding(data)
StaffService .up.> Controller : 1.2: success

' Staff Creation
StaffService .left.> StaffDB : 1.1.1: create Staff record
StaffDB .right.> StaffService : 1.1.2: return staffId

' User Creation Chain
StaffService ----> UserService : 1.1.3: createUserForStaff(staffId, data)
UserService ----> UserDB : 1.1.3.1: save User(Type='Staff')
UserDB .up.> UserService : 1.1.3.2: ok
UserService .left.> StaffService : 1.1.4: ok

@enduml