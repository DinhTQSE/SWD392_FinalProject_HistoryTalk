# .env.example
# Copy this file to .env and fill in your local values
# IMPORTANT: Add .env to .gitignore to prevent committing credentials

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/history_talk_db
DB_USER=postgres
DB_PASSWORD=123456

# JWT Configuration
# For local development, use any 32+ character string
# For production, generate with: openssl rand -base64 32
JWT_SECRET=your_local_secret_key_at_least_32_characters_long_12345678901

# Server Configuration
SERVER_PORT=8080

# Logging Level
LOG_LEVEL=DEBUG
