http://109.237.69.169 {
    # Java backend: keep /Historical-tell because OAuth and servlet paths depend on it.
    handle /Historical-tell/* {
        reverse_proxy http://historytalk-java:8080
    }

    # AI backend: FastAPI routers keep the /v1 prefix, so do not strip it.
    handle /v1/* {
        reverse_proxy http://historytalk-ai:8001
    }

    # AI health endpoint has no /v1 prefix.
    handle /health {
        reverse_proxy http://historytalk-ai:8001
    }
}
